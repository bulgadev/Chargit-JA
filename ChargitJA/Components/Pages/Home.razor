    <div class="card-body">
        <h5 class="card-title">Card title</h5>
        <p class="card-text">Some quick example text to build on the card.</p>
        <a href="#" class="btn btn-primary">Go somewhere</a>
    </div>
</div> *@

<div class="mt-5; pt-5">
    <button class="btn btn-primary" @onclick="LowNotification">
        Test Notification
    </button>

</div>

<p>@notificationStatus</p>
</div>

@code {


    private string notificationStatus = string.Empty;
    private System.ComponentModel.PropertyChangedEventHandler? batteryChangedHandler;

    protected override void OnInitialized()
    {
        batteryChangedHandler = (_, _) => _ = InvokeAsync(StateHasChanged);
        BatteryService.PropertyChanged += batteryChangedHandler;
    }

    public void Dispose()
    {
        if (batteryChangedHandler is not null)
        {
            BatteryService.PropertyChanged -= batteryChangedHandler;
        }
    }

    private void GoToDevices()
    {
        NavigationManager.NavigateTo("devices");
    }

    private void GoToSettingsPage()
    {
        NavigationManager.NavigateTo("settings");
    }

    private async Task LowNotification()
    {
        try
        {
            // Build a simple immediate notification for testing (no schedule)
            var request = new NotificationRequest
            {
                NotificationId = 1337,
                Title = "Battery Low",
                Description = "Your battery level is below 20%. Please charge your phone.",
                ReturningData = "Dummy data"
            };

            // Ensure we invoke the plugin on the main thread
            await MainThread.InvokeOnMainThreadAsync(() => LocalNotificationCenter.Current.Show(request));

            notificationStatus = "Notification sent (attempted).";
        }
        catch (Exception ex)
        {
            // Capture and show the exception so you can see what went wrong
            notificationStatus = $"Error sending notification: {ex.Message}";
            Console.WriteLine(ex);
        }

        StateHasChanged();
    }
}