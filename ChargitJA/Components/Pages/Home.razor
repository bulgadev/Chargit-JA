@page "/"

@using Microsoft.Maui.Devices
@using Plugin.LocalNotification
@using Plugin.LocalNotification.Core.Models
@using Microsoft.Maui.ApplicationModel

@inject BatteryService BatteryService
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="main-page">
<h1>Chargit</h1>
<h3>Never forget to charge your phone anymore!</h3>
<p>Right now you are at: @(BatteryService.BatteryLevel.ToString("P0"))</p>
<p>Status: @BatteryService.BatteryStatus</p>

<div class="mw-80">
    <p>See all your devices, change their settings, and see their battery</p>
    <div class="home-links">
        <button type="button" class="btn btn-primary home-button" @onclick="GoToDevices">
            Devices
        </button>

        <button type="button" class="btn btn-primary home-button" @onclick="GoToSettingsPage">
            Settings
        </button>
    </div>

    
    <p class="pt-3">Change your devic settings, so you always are 100%!</p>
    <button class="btn btn-primary home-button" @onclick="LowNotification">
        Settings
    </button>
</div>

